# Copy this file to .env and fill in real values before running docker-compose.
# Never commit .env to version control.

# Port uvicorn listens on inside the container
PORT=8000

# MLflow tracking database URI (SQLite file mounted as a volume)
MLFLOW_TRACKING_URI=sqlite:////data/mlruns.db

# (Optional) Set to 1 to enable debug-level logging
# DEBUG=0
